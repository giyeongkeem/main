# ──────────────────────────────────────────────────────────────
# 핏매치 환경변수 (예시)
# 로컬 개발은 아무 설정 없이도 동작합니다 — 데이터는 data/listings.json 에 저장됩니다.
# 실제 값을 쓰려면 이 파일을 .env.local 로 복사해서 채우세요.
# ──────────────────────────────────────────────────────────────

# 관리자 비밀번호 (미설정 시 기본값: admin1234)
ADMIN_PASSWORD="admin1234"

# 관리자 쿠키 서명용 시크릿 (운영 시 반드시 임의의 긴 문자열로 변경)
ADMIN_SECRET="change-this-to-a-long-random-string"

# PostgreSQL 연결 문자열을 넣으면 저장소가 자동으로 Postgres로 전환됩니다.
# (Supabase 예시: Project Settings → Database → Connection string → URI)
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
