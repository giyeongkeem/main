# ──────────────────────────────────────────────────────────────
# 핏매치 환경변수 (예시)  —  .env.local 로 복사해서 채우세요.
# 로컬 개발은 아무 설정 없이도 동작합니다(데이터=JSON 파일, 이미지=public/uploads).
# 아래 값을 채우면 해당 기능이 자동으로 켜집니다.
# ──────────────────────────────────────────────────────────────

# 관리자(마스터) ─────────────────────────────────────────────
ADMIN_PASSWORD="admin1234"                       # 미설정 시 기본값 admin1234
ADMIN_SECRET="change-this-to-a-long-random-string"

# 데이터베이스(PostgreSQL / Supabase) ───────────────────────
# 설정하면 저장소가 자동으로 Postgres로 전환됩니다.
# Supabase: Project Settings → Database → Connection string (URI)
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres"

# 이미지 저장(Supabase Storage) ─────────────────────────────
# 설정하면 업로드 이미지가 Supabase Storage(public 버킷)에 저장됩니다.
# Supabase: Project Settings → API 에서 URL 과 service_role 키 확인
# SUPABASE_URL="https://[REF].supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="..."
# SUPABASE_BUCKET="uploads"

# 소셜 로그인(Auth.js) ──────────────────────────────────────
# 세션 서명용 시크릿 (필수, 운영 시 임의의 긴 문자열)
#   생성 예:  openssl rand -base64 32
AUTH_SECRET="change-this-to-a-long-random-string"
# 배포 도메인 (예: https://fitmatch.vercel.app) — 자동 감지되지만 명시 권장
# AUTH_URL="https://your-domain.com"

# 카카오 — https://developers.kakao.com (REST API 키 / 보안 Client Secret)
#   Redirect URI: https://your-domain.com/api/auth/callback/kakao
# AUTH_KAKAO_ID=""
# AUTH_KAKAO_SECRET=""

# 네이버 — https://developers.naver.com/apps (Client ID / Secret)
#   Callback URL: https://your-domain.com/api/auth/callback/naver
# AUTH_NAVER_ID=""
# AUTH_NAVER_SECRET=""

# 애플 — https://developer.apple.com (유료 멤버십 필요)
#   AUTH_APPLE_ID = Services ID,  AUTH_APPLE_SECRET = .p8 키로 만든 JWT
#   JWT 생성:  node scripts/generate-apple-secret.mjs
#   Return URL: https://your-domain.com/api/auth/callback/apple
# AUTH_APPLE_ID=""
# AUTH_APPLE_SECRET=""
