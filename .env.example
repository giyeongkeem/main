# Required for real script generation (omit to fall back to fixture scripts)
ANTHROPIC_API_KEY=

# Optional: free key from https://www.pexels.com/api/ for stock background videos.
# Without it, segments use solid-color backgrounds.
PEXELS_API_KEY=

# Claude model used for script generation
# claude-fable-5 (최고 품질, $10/$50 per MTok) 또는 claude-opus-4-8 (절반 비용)
SHORTS_MODEL=claude-fable-5

# Set to 1 to force fixture scripts even when ANTHROPIC_API_KEY is set
MOCK_SCRIPT=

# Set to 1 to skip edge-tts and use silent placeholder audio (offline testing)
MOCK_TTS=

# Set when the dashboard is reachable beyond localhost. run.sh and
# run-public.sh generate one automatically. When set, every request needs HTTP
# Basic auth — any username, this password.
DASHBOARD_PASSWORD=

# Subtitle font burned into the video. Defaults to "Apple SD Gothic Neo" on
# macOS, "Noto Sans CJK KR" elsewhere. Override if your host uses another CJK
# font (Linux: sudo apt install fonts-noto-cjk).
SUBTITLE_FONT=

# Hard cap on finished video length in seconds (Shorts must stay <= 60).
MAX_VIDEO_SECONDS=58
