# ──────────────────────────────────────────────────────────────────────────
# Card News Studio — 환경 변수 예시
# 이 파일을 .env.local 로 복사한 뒤 키를 채워 넣으세요.  (cp .env.local.example .env.local)
#
# 키를 여기에 넣지 않아도 됩니다. 앱의 "설정"(⚙️) 화면에서 직접 입력하면
# 브라우저(localStorage)에 저장되어 요청 시 함께 전송됩니다. (혼자 쓰는 로컬 도구 기준)
# 보안을 더 원하면 키는 아래 환경 변수로만 넣고 설정 화면의 키 칸은 비워 두세요.
# ──────────────────────────────────────────────────────────────────────────

# Anthropic Claude API 키 (provider=claude 일 때)
ANTHROPIC_API_KEY=

# OpenAI API 키 (provider=openai 일 때)
OPENAI_API_KEY=

# (선택) 기본 모델 오버라이드 — 비워 두면 앱 기본값 사용
# CLAUDE_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-4o
